# ============================================================
# BOT-AUTO-TRADE-IG - Environment Configuration
# ============================================================
# Only infrastructure settings go here.
# IG credentials, risk params, and bot settings are configured
# from the web admin interface after first login.
# ============================================================

# Database (TimescaleDB)
DB_HOST=timescaledb
DB_PORT=5432
DB_NAME=trading_db
DB_USER=trader
DB_PASSWORD=change_me_strong_password_here

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_strong_password_here

# Dashboard
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000
DASHBOARD_SECRET_KEY=change_me_generate_with_openssl_rand_hex_32

# Domain & SSL (Let's Encrypt)
DOMAIN=trading.yourdomain.com
LETSENCRYPT_EMAIL=you@yourdomain.com

# Monitoring
GRAFANA_PASSWORD=admin_change_me

# Bot (defaults, overridden from web UI)
BOT_LOG_LEVEL=INFO
