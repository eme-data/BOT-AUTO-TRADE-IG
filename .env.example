# ============================================================
# BOT-AUTO-TRADE-IG — Environment Configuration
# ============================================================
# Run 'make install' or 'bash scripts/install.sh' for automatic
# setup — all secrets below are auto-generated for you.
#
# IG credentials, risk params, and bot settings are configured
# from the web admin interface after first login.
# ============================================================

# Database (TimescaleDB) — auto-generated by installer
DB_HOST=timescaledb
DB_PORT=5432
DB_NAME=trading_db
DB_USER=trader
DB_PASSWORD=change_me_strong_password_here

# Redis — auto-generated by installer
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_strong_password_here

# Dashboard — auto-generated by installer
# WARNING: Changing SECRET_KEY will invalidate all encrypted
# settings (IG credentials) stored in the database!
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000
DASHBOARD_SECRET_KEY=change_me_generate_with_openssl_rand_hex_32

# Admin account (first-time setup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_min_8_chars

# Domain & SSL (Let's Encrypt)
DOMAIN=trading.yourdomain.com
LETSENCRYPT_EMAIL=you@yourdomain.com

# Monitoring — auto-generated by installer
GRAFANA_PASSWORD=admin_change_me

# Bot (defaults, overridden from web UI)
BOT_LOG_LEVEL=INFO
