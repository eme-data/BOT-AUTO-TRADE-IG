{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Daily P&L",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "bot_daily_pnl",
          "legendFormat": "P&L"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0 }
            ]
          },
          "unit": "currencyEUR"
        }
      }
    },
    {
      "title": "Account Balance",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "bot_account_balance",
          "legendFormat": "Balance"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "currencyEUR" }
      }
    },
    {
      "title": "Open Positions",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "bot_open_positions",
          "legendFormat": "Positions"
        }
      ]
    },
    {
      "title": "Orders per Strategy",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "rate(bot_orders_total[5m])",
          "legendFormat": "{{strategy}} {{direction}}"
        }
      ]
    },
    {
      "title": "Order Latency",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(bot_order_latency_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.50, rate(bot_order_latency_seconds_bucket[5m]))",
          "legendFormat": "p50"
        }
      ]
    },
    {
      "title": "Signals Generated",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "rate(bot_signals_total[5m])",
          "legendFormat": "{{strategy}} {{signal_type}}"
        }
      ]
    },
    {
      "title": "Tick Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "rate(bot_ticks_total[1m])",
          "legendFormat": "{{epic}}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["trading"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "title": "IG Trading Bot",
  "uid": "ig-trading-bot"
}
